From d42ebb17a70179790722f20fbad9942972576c3c Mon Sep 17 00:00:00 2001
From: Sriram Nambakam <snambakam@linux.microsoft.com>
Date: Fri, 24 Apr 2026 17:33:34 -0700
Subject: [PATCH 01/11] Introduce VM Plane support with KVM

---
 include/standard-headers/linux/kvm_para.h |   3 +-
 target/i386/kvm/kvm.c                     | 160 ++++++++++++++++++++++
 2 files changed, 162 insertions(+), 1 deletion(-)

diff --git a/include/standard-headers/linux/kvm_para.h b/include/standard-headers/linux/kvm_para.h
index 015c166302..7a3d8ab1ff 100644
--- a/include/standard-headers/linux/kvm_para.h
+++ b/include/standard-headers/linux/kvm_para.h
@@ -27,9 +27,10 @@
 #define KVM_HC_MIPS_EXIT_VM		7
 #define KVM_HC_MIPS_CONSOLE_OUTPUT	8
 #define KVM_HC_CLOCK_PAIRING		9
-#define KVM_HC_SEND_IPI		10
+#define KVM_HC_SEND_IPI			10
 #define KVM_HC_SCHED_YIELD		11
 #define KVM_HC_MAP_GPA_RANGE		12
+#define KVM_HC_VM_PLANES_CONFIG		13
 
 /*
  * hypercalls use architecture specific
diff --git a/target/i386/kvm/kvm.c b/target/i386/kvm/kvm.c
index 9e352882c8..9665d83265 100644
--- a/target/i386/kvm/kvm.c
+++ b/target/i386/kvm/kvm.c
@@ -35,6 +35,8 @@
 #include "system/kvm_int.h"
 #include "system/runstate.h"
 #include "system/ramblock.h"
+#include "system/address-spaces.h"
+#include "system/memory.h"
 #include "kvm_i386.h"
 #include "../confidential-guest.h"
 #include "sev.h"
@@ -6516,10 +6518,168 @@ static int kvm_handle_hc_map_gpa_range(X86CPU *cpu, struct kvm_run *run)
     return 0;
 }
 
+/* VM planes ioctls not yet in linux-headers — defined in kernel's kvm.h */
+#define KVM_CREATE_PLANE        _IO(0xAE, 0xd6)
+#define KVM_CREATE_VCPU_PLANE   _IO(0xAE, 0xd7)
+
+static int kvm_handle_hc_vm_planes_config(X86CPU *cpu, struct kvm_run *run)
+{
+    uint64_t gpa = run->hypercall.args[0];
+    uint64_t plane_count = run->hypercall.args[1];
+    uint64_t plane_id;
+    unsigned int next_vcpu_id;
+    CPUState *cs;
+
+    if (!gpa || !plane_count || plane_count > 16) {
+        run->hypercall.ret = -EINVAL;
+        return 0;
+    }
+
+    /* Determine the next available vCPU ID (one past the highest existing). */
+    next_vcpu_id = 0;
+    CPU_FOREACH(cs) {
+        if ((unsigned int)cs->cpu_index >= next_vcpu_id) {
+            next_vcpu_id = cs->cpu_index + 1;
+        }
+    }
+
+    /* For each plane starting from plane_id=1 (plane 0 is boot/current plane) */
+    for (plane_id = 1; plane_id < plane_count; plane_id++) {
+        /*
+         * struct vm_plane_config layout (152 bytes each, 8-byte aligned):
+         *   uint64_t load_offset  (offset  0, 8 bytes)
+         *   uint64_t memory_size  (offset  8, 8 bytes)
+         *   uint32_t vcpu_count   (offset 16, 4 bytes)
+         *   char     kernel[128]  (offset 20, 128 bytes)
+         *   [4 bytes padding to align struct to 8]
+         */
+        uint64_t plane_gpa = gpa + (plane_id * 152);
+        uint64_t load_offset = 0, memory_size = 0;
+        uint32_t vcpu_count = 0;
+        MemTxResult res;
+        MemoryRegion *mr;
+        Error *err = NULL;
+        char name[64];
+        int plane_fd;
+        unsigned int i;
+
+        /* Read load_offset */
+        res = address_space_read(&address_space_memory, plane_gpa,
+                                 MEMTXATTRS_UNSPECIFIED, &load_offset, 8);
+        if (res != MEMTX_OK) {
+            run->hypercall.ret = -EIO;
+            return 0;
+        }
+
+        /* Read memory_size */
+        res = address_space_read(&address_space_memory, plane_gpa + 8,
+                                 MEMTXATTRS_UNSPECIFIED, &memory_size, 8);
+        if (res != MEMTX_OK) {
+            run->hypercall.ret = -EIO;
+            return 0;
+        }
+
+        /* Read vcpu_count */
+        res = address_space_read(&address_space_memory, plane_gpa + 16,
+                                 MEMTXATTRS_UNSPECIFIED, &vcpu_count, 4);
+        if (res != MEMTX_OK) {
+            run->hypercall.ret = -EIO;
+            return 0;
+        }
+
+        if (!load_offset || !memory_size || !vcpu_count) {
+            error_report("vm_planes: plane %" PRIu64 " has invalid config "
+                         "(load_offset=0x%" PRIx64 " memory_size=0x%" PRIx64
+                         " vcpu_count=%" PRIu32 ")",
+                         plane_id, load_offset, memory_size, vcpu_count);
+            run->hypercall.ret = -EINVAL;
+            return 0;
+        }
+
+        /*
+         * Step 1: Create the KVM plane object. KVM_CREATE_PLANE takes the
+         * plane ID as argument and returns a plane fd.
+         */
+        plane_fd = kvm_vm_ioctl(kvm_state, KVM_CREATE_PLANE, (int)plane_id);
+        if (plane_fd < 0) {
+            error_report("vm_planes: KVM_CREATE_PLANE failed for plane %"
+                         PRIu64 ": %s", plane_id, strerror(errno));
+            run->hypercall.ret = -errno;
+            return 0;
+        }
+
+        /*
+         * Step 2: Allocate RAM for this plane and register it with KVM
+         * at load_offset in the guest physical address space.
+         * memory_region_add_subregion() requires the BQL; the KVM memory
+         * listener will call KVM_SET_USER_MEMORY_REGION to register the slot.
+         */
+        snprintf(name, sizeof(name), "vm-plane-ram-%" PRIu64, plane_id);
+        mr = g_new0(MemoryRegion, 1);
+        if (!memory_region_init_ram(mr, NULL, name, memory_size, &err)) {
+            error_report("vm_planes: failed to allocate RAM for plane %" PRIu64
+                         ": %s", plane_id, error_get_pretty(err));
+            error_free(err);
+            g_free(mr);
+            close(plane_fd);
+            run->hypercall.ret = -ENOMEM;
+            return 0;
+        }
+
+        bql_lock();
+        memory_region_add_subregion(get_system_memory(), load_offset, mr);
+        bql_unlock();
+
+        /*
+         * Step 3: Create vCPUs for this plane. For each vCPU:
+         *   a) KVM_CREATE_VCPU on the VM fd to get a new vCPU fd.
+         *   b) KVM_CREATE_VCPU_PLANE on the plane fd, passing the vCPU fd,
+         *      to assign the vCPU to the plane.
+         */
+        for (i = 0; i < vcpu_count; i++) {
+            int vcpu_fd, ret;
+
+            vcpu_fd = kvm_vm_ioctl(kvm_state, KVM_CREATE_VCPU, next_vcpu_id);
+            if (vcpu_fd < 0) {
+                error_report("vm_planes: KVM_CREATE_VCPU failed for plane %"
+                             PRIu64 " vcpu %u: %s",
+                             plane_id, next_vcpu_id, strerror(errno));
+                close(plane_fd);
+                run->hypercall.ret = -errno;
+                return 0;
+            }
+
+            ret = ioctl(plane_fd, KVM_CREATE_VCPU_PLANE, vcpu_fd);
+            close(vcpu_fd);
+            if (ret < 0) {
+                error_report("vm_planes: KVM_CREATE_VCPU_PLANE failed for "
+                             "plane %" PRIu64 " vcpu %u: %s",
+                             plane_id, next_vcpu_id, strerror(errno));
+                close(plane_fd);
+                run->hypercall.ret = -errno;
+                return 0;
+            }
+
+            next_vcpu_id++;
+        }
+
+        close(plane_fd);
+
+        info_report("vm_planes: plane %" PRIu64 " ready — GPA 0x%" PRIx64
+                    " size 0x%" PRIx64 " vcpus %u",
+                    plane_id, load_offset, memory_size, vcpu_count);
+    }
+
+    run->hypercall.ret = 0;
+    return 0;
+}
+
 static int kvm_handle_hypercall(X86CPU *cpu, struct kvm_run *run)
 {
     if (run->hypercall.nr == KVM_HC_MAP_GPA_RANGE)
         return kvm_handle_hc_map_gpa_range(cpu, run);
+    if (run->hypercall.nr == KVM_HC_VM_PLANES_CONFIG)
+        return kvm_handle_hc_vm_planes_config(cpu, run);
 
     return -EINVAL;
 }
-- 
