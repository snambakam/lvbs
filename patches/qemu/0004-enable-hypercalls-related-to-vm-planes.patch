-            ctx->result = 0;
-            goto done;
+            /* Signal boot complete on first HLT, then keep running.
+             * The kernel enters HLT in its idle loop after boot.
+             * Sleep briefly to avoid burning 100% host CPU on idle. */
+            if (!boot_signaled) {
+                boot_signaled = true;
+                qemu_mutex_lock(ctx->mutex);
+                (*ctx->halted_count)++;
+                qemu_cond_signal(ctx->cond);
+                qemu_mutex_unlock(ctx->mutex);
+            }
+            /* Let the host CPU rest while the guest is idle */
+            usleep(1000); /* 1ms */
+            break;
         case KVM_EXIT_IO:
+            /*
+             * Minimal Plane 1 COM1 emulation:
+             * - OUT 0x3f8 bytes are captured to the Plane 1 serial log.
+             * - IN reads return values that make the 8250 earlycon driver
+             *   believe a functional UART is present and ready to transmit.
+             */
+            {
+                uint8_t *io_data = (uint8_t *)kvm_run + kvm_run->io.data_offset;
+                size_t io_size = kvm_run->io.size * kvm_run->io.count;
+                uint16_t port = kvm_run->io.port;
+
+                if (kvm_run->io.direction == KVM_EXIT_IO_OUT) {
+                    if (port == 0x3f8 && ctx->log_fd >= 0) {
+                        ssize_t written = write(ctx->log_fd, io_data, io_size);
+                        (void)written;
+                    }
+                } else if (kvm_run->io.direction == KVM_EXIT_IO_IN) {
+                    /* Default: return 0 for unknown ports */
+                    memset(io_data, 0, io_size);
+
+                    switch (port) {
+                    case 0x3f8: /* RBR/THR - receive buffer (no data) */
+                        break;
+                    case 0x3f9: /* IER - interrupt enable register */
+                        break;
+                    case 0x3fa: /* IIR - no interrupt pending */
+                        memset(io_data, 0xc1, io_size); /* FIFO enabled, no IRQ */
+                        break;
+                    case 0x3fb: /* LCR - line control register */
+                        memset(io_data, 0x03, io_size); /* 8N1 */
+                        break;
+                    case 0x3fc: /* MCR - modem control register */
+                        memset(io_data, 0x08, io_size); /* OUT2 enabled */
+                        break;
+                    case 0x3fd: /* LSR - tx ready, tx empty */
+                        memset(io_data, 0x60, io_size); /* THRE | TEMT */
+                        break;
+                    case 0x3fe: /* MSR - modem status */
+                        memset(io_data, 0xb0, io_size); /* CTS|DSR|CD */
+                        break;
+                    case 0x3ff: /* scratch register */
+                        break;
