+/*
+ * Minimal boot_params (zero-page) written into plane guest RAM so the plane
+ * kernel receives a valid x86 boot protocol handoff via rsi.
+ * Only the fields the kernel actually checks on a direct 64-bit entry are set.
+ */
+struct plane_boot_params {
+    uint8_t  pad0[0x1f1];              /* everything before setup_header */
+    /* setup_header fields we care about (offset 0x1f1) */
+    uint8_t  setup_sects;              /* 0x1f1 */
+    uint8_t  pad1[13];                 /* 0x1f2..0x1fe */
+    uint16_t boot_flag;                /* 0x1ff  must be 0xAA55 */
+    uint8_t  pad2[2];                  /* 0x201..0x202 */
+    uint32_t header;                   /* 0x202  "HdrS" magic */
+    uint16_t version;                  /* 0x206  boot protocol version */
+    uint8_t  pad3[8];                  /* 0x208..0x20f */
+    uint8_t  type_of_loader;           /* 0x210 */
+    uint8_t  loadflags;                /* 0x211 */
+    uint8_t  pad4[2];                  /* 0x212..0x213 */
+    uint32_t cmd_line_ptr;             /* 0x228 — low 32 bits of cmdline GPA */
+    uint8_t  pad5[212];                /* fill to 0x300 */
+    uint8_t  e820_entries;             /* 0x1e8, adjusted in pad */
+} __attribute__((packed));
+
 static int kvm_init_plane_vcpu(int vcpu_fd, uint64_t entry_addr,
-                               uint64_t stack_addr)
+                               uint64_t stack_addr, uint64_t zero_page_gpa,
