+              | (1u << 5)   /* NE - numeric error (required by VMX) */
+              | (1u << 16)  /* WP - write protect */
+              | (1u << 31); /* PG - paging */
+    sregs.efer = (1u << 0)  /* SCE - syscall extensions */
