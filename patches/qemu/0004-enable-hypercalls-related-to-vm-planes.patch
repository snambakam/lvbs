+     *
+     * Identity-mapped page tables must already be written at
+     * page_table_gpa before calling this function.
      */
 
     /* Segment descriptors for flat 64-bit code/data */
@@ -6746,12 +6842,58 @@ static int kvm_init_plane_vcpu(int vcpu_fd, uint64_t entry_addr,
     sregs.es = sregs.ds;
     sregs.ss = sregs.ds;
 
-    /* Control registers for 64-bit mode with paging disabled initially */
-    sregs.cr0 = (1u << 0)   /* PE - protected mode */
-              | (1u << 4);   /* ET - x87 extension type */
+    /* FS and GS: unused, mark as unusable for VMX */
+    sregs.fs.selector = 0;
+    sregs.fs.base = 0;
+    sregs.fs.limit = 0xffffffff;
+    sregs.fs.type = 0x3;
+    sregs.fs.present = 1;
+    sregs.fs.dpl = 0;
+    sregs.fs.db = 1;
+    sregs.fs.s = 1;
+    sregs.fs.g = 1;
+    sregs.gs = sregs.fs;
+
+    /* GDT: point to a minimal GDT written to guest memory */
+    sregs.gdt.base = gdt_gpa;
+    sregs.gdt.limit = 0x2f;  /* 6 entries * 8 bytes - 1 */
+
+    /* IDT: empty but valid */
+    sregs.idt.base = 0;
+    sregs.idt.limit = 0xffff;
+
+    /* TR: required by VMX, minimal valid 64-bit TSS descriptor */
+    sregs.tr.base = 0;
+    sregs.tr.limit = 0x67;
+    sregs.tr.selector = 0x28;
+    sregs.tr.type = 0xb;   /* 64-bit busy TSS */
+    sregs.tr.present = 1;
+    sregs.tr.dpl = 0;
+    sregs.tr.db = 0;
+    sregs.tr.s = 0;        /* system segment */
+    sregs.tr.l = 0;
+    sregs.tr.g = 0;
+
+    /* LDT: null */
+    sregs.ldt.base = 0;
