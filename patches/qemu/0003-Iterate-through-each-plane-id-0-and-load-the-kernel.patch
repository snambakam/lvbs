From 287e206b187d4863e76256c15e947b4be95e0d69 Mon Sep 17 00:00:00 2001
From: Sriram Nambakam <snambakam@linux.microsoft.com>
Date: Tue, 28 Apr 2026 15:36:45 -0700
Subject: [PATCH 03/11] Iterate through each plane (id > 0) and load the
 kernel. - wait till all the vCPUs associated with that plane halt

---
 target/i386/kvm/kvm.c | 169 +++++++++++++++++++++++++++++++++++++++++-
 1 file changed, 166 insertions(+), 3 deletions(-)

diff --git a/target/i386/kvm/kvm.c b/target/i386/kvm/kvm.c
index 301e32d97d..a708e85c2a 100644
--- a/target/i386/kvm/kvm.c
+++ b/target/i386/kvm/kvm.c
@@ -21,6 +21,7 @@
 #include <sys/utsname.h>
 #include <sys/syscall.h>
 #include <sys/resource.h>
+#include <sys/mman.h>
 
 #include <linux/kvm.h>
 #include <linux/kvm_para.h>
@@ -48,6 +49,7 @@
 #include "gdbstub/enums.h"
 #include "qemu/host-utils.h"
 #include "qemu/main-loop.h"
+#include "qemu/thread.h"
 #include "qemu/ratelimit.h"
 #include "qemu/config-file.h"
 #include "qemu/error-report.h"
@@ -6779,11 +6781,106 @@ static int kvm_init_plane_vcpu(int vcpu_fd, uint64_t entry_addr,
     return 0;
 }
 
+struct vm_plane_boot_ctx {
+    int vcpu_fd;
+    int vcpu_mmap_size;
+    unsigned int vcpu_idx;
+    uint64_t plane_id;
+    unsigned int *halted_count;
+    QemuMutex *mutex;
+    QemuCond *cond;
+    int result;
+};
+
+static void *vm_plane_vcpu_thread(void *arg)
+{
+    struct vm_plane_boot_ctx *ctx = arg;
+    struct kvm_run *kvm_run;
+    int ret;
+
+    kvm_run = mmap(NULL, ctx->vcpu_mmap_size, PROT_READ | PROT_WRITE,
+                   MAP_SHARED, ctx->vcpu_fd, 0);
+    if (kvm_run == MAP_FAILED) {
+        error_report("vm_planes: plane %" PRIu64 " vcpu %u: "
+                     "mmap kvm_run failed: %s",
+                     ctx->plane_id, ctx->vcpu_idx, strerror(errno));
+        ctx->result = -errno;
+        qemu_mutex_lock(ctx->mutex);
+        (*ctx->halted_count)++;
+        qemu_cond_signal(ctx->cond);
+        qemu_mutex_unlock(ctx->mutex);
+        return NULL;
+    }
+
+    for (;;) {
+        ret = ioctl(ctx->vcpu_fd, KVM_RUN, 0);
+        if (ret < 0) {
+            if (errno == EINTR || errno == EAGAIN) {
+                continue;
+            }
+            error_report("vm_planes: plane %" PRIu64 " vcpu %u: "
+                         "KVM_RUN failed: %s",
+                         ctx->plane_id, ctx->vcpu_idx, strerror(errno));
+            ctx->result = -errno;
+            break;
+        }
+
+        switch (kvm_run->exit_reason) {
+        case KVM_EXIT_HLT:
+            ctx->result = 0;
+            goto done;
+        case KVM_EXIT_IO:
+        case KVM_EXIT_MMIO:
+            /* Ignore I/O during plane boot */
+            break;
+        case KVM_EXIT_SHUTDOWN:
+            error_report("vm_planes: plane %" PRIu64 " vcpu %u: "
+                         "shutdown during boot",
+                         ctx->plane_id, ctx->vcpu_idx);
+            ctx->result = -EFAULT;
+            goto done;
+        case KVM_EXIT_FAIL_ENTRY:
+            error_report("vm_planes: plane %" PRIu64 " vcpu %u: "
+                         "entry failure: hw_entry_failure_reason=0x%" PRIx64,
+                         ctx->plane_id, ctx->vcpu_idx,
+                         (uint64_t)kvm_run->fail_entry
+                             .hardware_entry_failure_reason);
+            ctx->result = -EFAULT;
+            goto done;
+        case KVM_EXIT_INTERNAL_ERROR:
+            error_report("vm_planes: plane %" PRIu64 " vcpu %u: "
+                         "internal error: suberror=%u",
+                         ctx->plane_id, ctx->vcpu_idx,
+                         kvm_run->internal.suberror);
+            ctx->result = -EFAULT;
+            goto done;
+        default:
+            error_report("vm_planes: plane %" PRIu64 " vcpu %u: "
+                         "unexpected exit reason %u",
+                         ctx->plane_id, ctx->vcpu_idx,
+                         kvm_run->exit_reason);
+            ctx->result = -EFAULT;
+            goto done;
+        }
+    }
+
+done:
+    munmap(kvm_run, ctx->vcpu_mmap_size);
+
+    qemu_mutex_lock(ctx->mutex);
+    (*ctx->halted_count)++;
+    qemu_cond_signal(ctx->cond);
+    qemu_mutex_unlock(ctx->mutex);
+
+    return NULL;
+}
+
 static int kvm_handle_hc_vm_planes_activate(X86CPU *cpu, struct kvm_run *run)
 {
     uint64_t plane_count = run->hypercall.args[0];
     uint64_t plane_id;
     KVMState *s = kvm_state;
+    int vcpu_mmap_size;
 
     if (!plane_count || plane_count > s->vm_planes_max ||
         plane_count != s->vm_plane_count) {
@@ -6791,11 +6888,24 @@ static int kvm_handle_hc_vm_planes_activate(X86CPU *cpu, struct kvm_run *run)
         return 0;
     }
 
+    vcpu_mmap_size = kvm_ioctl(s, KVM_GET_VCPU_MMAP_SIZE, 0);
+    if (vcpu_mmap_size <= 0) {
+        error_report("vm_planes: KVM_GET_VCPU_MMAP_SIZE failed");
+        run->hypercall.ret = -EINVAL;
+        return 0;
+    }
+
     for (plane_id = 1; plane_id < plane_count; plane_id++) {
         struct kvm_vm_plane_state *ps = &s->vm_planes[plane_id];
         uint64_t entry_addr = ps->load_offset;
         uint64_t stack_addr = ps->load_offset + ps->memory_size;
+        struct vm_plane_boot_ctx *ctxs;
+        QemuThread *threads;
+        QemuMutex mutex;
+        QemuCond cond;
+        unsigned int halted_count = 0;
         unsigned int i;
+        int err = 0;
 
         if (!ps->plane_fd || !ps->vcpu_count) {
             error_report("vm_planes: plane %" PRIu64 " not configured",
@@ -6804,6 +6914,7 @@ static int kvm_handle_hc_vm_planes_activate(X86CPU *cpu, struct kvm_run *run)
             return 0;
         }
 
+        /* Initialize vCPU registers */
         for (i = 0; i < ps->vcpu_count; i++) {
             int ret = kvm_init_plane_vcpu(ps->vcpu_fds[i],
                                           entry_addr, stack_addr);
@@ -6815,9 +6926,61 @@ static int kvm_handle_hc_vm_planes_activate(X86CPU *cpu, struct kvm_run *run)
             }
         }
 
-        info_report("vm_planes: plane %" PRIu64 " activated — entry 0x%"
-                    PRIx64 " stack 0x%" PRIx64 " vcpus %u",
-                    plane_id, entry_addr, stack_addr, ps->vcpu_count);
+        /* Set up synchronization and spawn vCPU threads */
+        qemu_mutex_init(&mutex);
+        qemu_cond_init(&cond);
+
+        ctxs = g_new0(struct vm_plane_boot_ctx, ps->vcpu_count);
+        threads = g_new0(QemuThread, ps->vcpu_count);
+
+        for (i = 0; i < ps->vcpu_count; i++) {
+            char name[48];
+
+            ctxs[i].vcpu_fd = ps->vcpu_fds[i];
+            ctxs[i].vcpu_mmap_size = vcpu_mmap_size;
+            ctxs[i].vcpu_idx = i;
+            ctxs[i].plane_id = plane_id;
+            ctxs[i].halted_count = &halted_count;
+            ctxs[i].mutex = &mutex;
+            ctxs[i].cond = &cond;
+            ctxs[i].result = 0;
+
+            snprintf(name, sizeof(name),
+                     "plane%" PRIu64 "-vcpu%u", plane_id, i);
+            qemu_thread_create(&threads[i], name, vm_plane_vcpu_thread,
+                               &ctxs[i], QEMU_THREAD_JOINABLE);
+        }
+
+        /* Wait for all vCPUs to HLT */
+        qemu_mutex_lock(&mutex);
+        while (halted_count < ps->vcpu_count) {
+            qemu_cond_wait(&cond, &mutex);
+        }
+        qemu_mutex_unlock(&mutex);
+
+        /* Join all threads and check results */
+        for (i = 0; i < ps->vcpu_count; i++) {
+            qemu_thread_join(&threads[i]);
+            if (ctxs[i].result && !err) {
+                err = ctxs[i].result;
+            }
+        }
+
+        qemu_cond_destroy(&cond);
+        qemu_mutex_destroy(&mutex);
+        g_free(threads);
+        g_free(ctxs);
+
+        if (err) {
+            error_report("vm_planes: plane %" PRIu64 " boot failed: %d",
+                         plane_id, err);
+            run->hypercall.ret = err;
+            return 0;
+        }
+
+        info_report("vm_planes: plane %" PRIu64 " booted — entry 0x%"
+                    PRIx64 " vcpus %u",
+                    plane_id, entry_addr, ps->vcpu_count);
     }
 
     run->hypercall.ret = 0;
-- 
2.53.0

