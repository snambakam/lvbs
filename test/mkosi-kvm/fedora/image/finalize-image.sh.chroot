#!/usr/bin/env bash
set -euxo pipefail

# Finalize image build: configure systemd-boot for UKI layout and VTL0/VTL1 plane support.
# VTL1 kernel payload is staged under /boot for initrd embedding.

echo "========== FINALIZATION INSTRUMENTATION =========="
echo "[INSTRUMENTATION] Finalizing image with VTL0/VTL1 plane support"

VTL1_KERNEL="/boot/plane-1/vmlinux"

echo "[INSTRUMENTATION] Checking plane kernel payload availability:"

# Check VTL1 kernel (uncompressed vmlinux)
if [ ! -f "$VTL1_KERNEL" ]; then
	echo "[ERROR] VTL1 kernel (vmlinux) NOT found at $VTL1_KERNEL"
	exit 1
else
	echo "[SUCCESS] VTL1 kernel (vmlinux - uncompressed) found at $VTL1_KERNEL"
	echo "  Size: $(stat -c%s "$VTL1_KERNEL") bytes"
	echo "  SHA256: $(sha256sum "$VTL1_KERNEL" | cut -d' ' -f1)"
fi
# Create kernel install configuration for UKI layout
mkdir -p /etc/kernel
cat > /etc/kernel/install.conf <<'EOF'
layout=uki
EOF

# Set kernel command line for console and logging
cat > /etc/kernel/cmdline <<'EOF'
console=ttyS0 console=tty0 rd.systemd.show_status=true
EOF

echo "[INSTRUMENTATION] Kernel command line configured:"
echo "  Content: $(cat /etc/kernel/cmdline)"

echo ""
echo "========== FINALIZATION COMPLETE =========="
echo "[INSTRUMENTATION] Image finalization complete:"
echo "  VTL1 kernel payload (vmlinux): $VTL1_KERNEL"
echo "[INSTRUMENTATION] VTL0 kernel will verify VTL1 kernel SHA256, place it into Plane 1, and launch it via hypercall"
